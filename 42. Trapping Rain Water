class Solution {
public:
    int trap(vector<int>& height) {
        int n = height.size();
        vector<int> left_max1(n);
        vector<int> right_max1(n);
        int unit =0;
        int left_max = 0;
        for(int i =0; i<n ; i++){
            
            left_max = max(left_max, height[i]);
            left_max1[i] = left_max;

        }
        int right_max = 0;
        for(int i =n-1; i>=0 ; i--){
           
            right_max = max(right_max, height[i]);
            right_max1[i] = right_max;
        }
        for(int i = 0; i<n; i++){
             unit += min(left_max1[i], right_max1[i]) - height[i];
        }
        return unit;
        
    }
};
