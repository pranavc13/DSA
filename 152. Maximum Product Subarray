class Solution {
public:
    int maxProduct(vector<int>& nums) {
       int n = nums.size();
       int minEnding = nums[0];
       int maxEnding = nums[0];
       int ans = nums[0];

       for(int i=1; i<n; i++){
        if(nums[i]<0){
            swap(minEnding, maxEnding);
        }
        maxEnding = max(nums[i], nums[i]*maxEnding);
        minEnding = min(nums[i], nums[i]*minEnding);
        ans = max(maxEnding, ans);
       }
       return ans;
        
    }
};
