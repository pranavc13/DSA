class Solution {
public:
    int solve(vector<vector<int>>& grid, int i, int j){
        int m  = grid.size();
        int n  = grid[0].size();

        if(i<0 || i>=m || j<0 || j>=n || grid[i][j] == 0){
            return 0;
        }
        int currGold = grid[i][j];
        grid[i][j] = 0;
        
        int maxgoldfromhere = 0;
        maxgoldfromhere = max(maxgoldfromhere, solve(grid, i, j+1 ));
        maxgoldfromhere = max(maxgoldfromhere, solve(grid, i, j-1));
        maxgoldfromhere = max(maxgoldfromhere, solve(grid, i+1, j));
        maxgoldfromhere = max(maxgoldfromhere, solve(grid, i-1, j));

        grid[i][j] = currGold;
        return maxgoldfromhere + currGold;
    }
    int getMaximumGold(vector<vector<int>>& grid) {
        int maxGold = 0;
        int m  = grid.size();
        int n  = grid[0].size();
        for(int i=0; i<m; i++){
            for(int j = 0; j<n; j++){
                if(grid[i][j] != 0){
                   maxGold = max(maxGold, solve(grid, i, j));

                }
            }
        }
        return maxGold;


        
    }
};
