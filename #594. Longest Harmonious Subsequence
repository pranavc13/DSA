class Solution {
public:
    int findLHS(vector<int>& nums) {
        unordered_map<int, int> freq;
        for (int num : nums) {
            freq[num]++;
        }
        
       int maxLength = 0;
        for (auto& p : freq) {
            int num = p.first;
            if (freq.count(num + 1)) {
                maxLength = max(maxLength, freq[num] + freq[num + 1]);
            }
        }
        return maxLength;
    }
};
