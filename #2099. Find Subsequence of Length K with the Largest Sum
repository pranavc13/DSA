class Solution {
public:
    vector<int> maxSubsequence(vector<int>& nums, int k) {
                int n = nums.size();
        vector<pair<int, int>> numIndices;
        
        for (int i = 0; i < n; i++) {
            numIndices.push_back({nums[i], i});
        }
        
        sort(numIndices.begin(), numIndices.end(), [](const pair<int, int>& a, const pair<int, int>& b) {
            return a.first > b.first;
        });
        
        vector<int> indices;
        for (int i = 0; i < k; i++) {
            indices.push_back(numIndices[i].second);
        }
        
        sort(indices.begin(), indices.end());
        
        vector<int> result;
        for (int idx : indices) {
            result.push_back(nums[idx]);
        }
        
        return result;
        
    }
};
