class Solution {
public:
    int longestConsecutive(vector<int>& nums) {
        sort(nums.begin(), nums.end());
        int n = nums.size();
        if(n==0){
            return 0;
        }
        int count =0;
        int current=1;
        int maximum =1;
        
        for(int i=1; i<n; i++){
            if(nums[i] == nums[i-1]){
                continue;
            }
            if(nums[i] - nums[i-1] == 1 ){
             current++;
             maximum = max(maximum, current);
            }
            
            
            else{
               current = 1;
            }



        }
        return maximum;
        
    }
};
