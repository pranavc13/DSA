class Solution {
public:
    void merge(vector<int>& nums1, int m, vector<int>& nums2, int n) {
        int i = 0; 
        int j = 0; 

        while (j < n) {
            
            if (i >= m) {
                nums1[i] = nums2[j];
                i++;
                j++;
                m++; // 
            }
            else if (nums2[j] <= nums1[i]) {

                
                for (int k = m; k > i; k--) {
                    nums1[k] = nums1[k - 1];
                }

                
                nums1[i] = nums2[j];

                i++;
                j++;
                m++; 
            }
            else {
                i++;
            }
        }
    }
};
