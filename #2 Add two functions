class Solution {
public:

    ListNode* ReverseLL(ListNode* head){
        if(!head || !head->next){
            return head;
        }

        ListNode* newHead = ReverseLL(head->next);
        head->next->next = head;
        head->next = nullptr;

        return newHead;
    }

    ListNode* addTwoNumbers(ListNode* l1, ListNode* l2) {

        // Step 1: Reverse both lists
        l1 = ReverseLL(l1);
        l2 = ReverseLL(l2);

        int carry = 0;

        // Dummy node to build answer
        ListNode* dummy = new ListNode(0);
        ListNode* temp = dummy;

        // Step 2: Add while any list exists or carry remains
        while(l1 != nullptr || l2 != nullptr || carry != 0){

            int sum = carry;

            if(l1){
                sum += l1->val;
                l1 = l1->next;
            }

            if(l2){
                sum += l2->val;
                l2 = l2->next;
            }

            carry = sum / 10;
            int digit = sum % 10;

            temp->next = new ListNode(digit);
            temp = temp->next;
        }

        // Step 3: Reverse result back
        return ReverseLL(dummy->next);
    }
};
