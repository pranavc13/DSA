class Solution {
public:
    vector<int> findKDistantIndices(vector<int>& nums, int key, int k) {
                int n = nums.size();
        vector<int> result;
        vector<int> keyIndices;
        
        for (int j = 0; j < n; j++) {
            if (nums[j] == key) {
                keyIndices.push_back(j);
            }
        }
        
        for (int i = 0; i < n; i++) {
            for (int keyIdx : keyIndices) {
                if (abs(i - keyIdx) <= k) {
                    result.push_back(i);
                    break;
                }
            }
        }
        
        sort(result.begin(), result.end());
        
        return result;
        
    }
};
