class Solution {
public:
    
    vector<vector<int>>ans;
    void solve(int idx,vector<int>& nums ) {
        int n  = nums.size();
        if(idx == nums.size()){
            ans.push_back(nums);
            return;
        }
        unordered_set<int> set;
        for(int i=idx; i<nums.size(); i++ ){
            if(set.count(nums[i])>0){
                continue;
            }
            set.insert(nums[i]);
            swap(nums[idx], nums[i]);
            solve(idx+1, nums);
            swap(nums[idx], nums[i]);
        }
    }
    vector<vector<int>>permuteUnique(vector<int>& nums) {
        
        solve(0, nums);
        return ans;             
    }
};
