class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        unordered_map <int, int> nums2;
        int n = nums.size();
        for(int i=0; i<n ; i++ ){
            int complement = target-nums[i];
            if(nums2.find(complement)!= nums2.end()){
                return {nums2[complement], i};

            }
            nums2[nums[i]] =i;

         

         }
         return {};


         
        }

        
    
};
